  { de: "das Ladegerät", fr: ["le chargeur"], isImg: true }
];

// --- LOGIK ---
let currentIdx = 0;
let starred = JSON.parse(localStorage.getItem('starredVocab') || '[]');
const themes = ['cyber','ocean','forest','sunset','lava','space','gold','neon','royal'];

function init() {
  createParticles();
  createThemeDots();
  showNext();
  
  // Enter Taste Unterstützung
  document.getElementById('answerInput').addEventListener('keypress', (e) => {
  if(e.key === 'Enter') {
    check(); // Macht jetzt bei jedem Enter-Druck nur den Check
  }
});

}

function showNext() {
  const starOnly = document.getElementById('starOnlyToggle').checked;
  let pool = vocabulaire;
  
  if(starOnly) {
    pool = vocabulaire.filter(v => starred.includes(v.de));
    if(pool.length === 0) {
      alert("Du hast noch keine Wörter mit Stern markiert! Übe erst einmal alle.");
      document.getElementById('starOnlyToggle').checked = false;
      pool = vocabulaire;
    }
  }

  currentIdx = vocabulaire.indexOf(pool[Math.floor(Math.random() * pool.length)]);
  
  document.getElementById('vocabDisplay').innerText = vocabulaire[currentIdx].de;
  document.getElementById('answerInput').value = '';
  document.getElementById('answerInput').focus();
  document.getElementById('feedback').innerText = '';
  document.getElementById('feedback').className = 'feedback';
  updateStarUI();
}

function check() {
  const input = document.getElementById('answerInput').value.trim().toLowerCase();
  const correctOnes = vocabulaire[currentIdx].fr.map(v => v.toLowerCase());
  const feedback = document.getElementById('feedback');

  if(correctOnes.includes(input)) {
    feedback.innerText = "RICHTIG! 🔥";
    feedback.className = "feedback correct";
  } else {
    feedback.innerText = `FALSCH! Lösung: ${vocabulaire[currentIdx].fr[0]}`;
    feedback.className = "feedback wrong";
  }
}

function toggleStar() {
  const word = vocabulaire[currentIdx].de;
  if(starred.includes(word)) {
    starred = starred.filter(w => w !== word);
  } else {
    starred.push(word);
  }
  localStorage.setItem('starredVocab', JSON.stringify(starred));
  updateStarUI();
}

function updateStarUI() {
  const btn = document.getElementById('starBtn');
  btn.innerText = starred.includes(vocabulaire[currentIdx].de) ? '★' : '☆';
}

function toggleSettings() {
  document.getElementById('settingsModal').classList.toggle('active');
}

function createThemeDots() {
  const grid = document.getElementById('themeGrid');
  themes.forEach(t => {
    const dot = document.createElement('div');
    dot.className = `theme-dot theme-${t}`;
    dot.style.background = `var(--accent)`; // Vereinfacht für das Beispiel
    dot.onclick = () => document.body.className = `theme-${t}`;
    grid.appendChild(dot);
  });
}

function createParticles() {
  const p = document.getElementById('particles');
  for(let i=0; i<30; i++) {
    const div = document.createElement('div');
    div.className = 'particle';
    div.style.left = Math.random() * 100 + 'vw';
    div.style.width = div.style.height = Math.random() * 6 + 2 + 'px';
    div.style.animationDelay = Math.random() * 10 + 's';
    p.appendChild(div);
  }
}
init();
</script>
</body>
</html>
